# Skopiuj ten plik jako .env i uzupelnij wartosci.
# Aplikacja dziala bez kluczy (tryb mock/offline) - klucze wlaczaja integracje na zywo.

# Tryb klienta zagrozen:
#   mock  -> bez sieci, deterministyczna heurystyka demonstracyjna (domyslny)
#   live  -> realne zapytania do Google Safe Browsing i/lub PhishTank
THREAT_CLIENT_MODE=mock

# Google Safe Browsing API (tylko w trybie live).
# Klucz z Google Cloud Console -> wlaczona usluga "Safe Browsing API".
GOOGLE_SAFE_BROWSING_API_KEY=

# PhishTank - dziala takze BEZ klucza (nizszy limit zapytan).
# Klucz z darmowej rejestracji na phishtank.org zwieksza limit.
PHISHTANK_APP_KEY=

# Prog scoringu (0-100), powyzej ktorego URL uznajemy za phishing
PHISHING_THRESHOLD=50

# Timeout zapytan HTTP do zewnetrznych API (sekundy)
HTTP_TIMEOUT=5
